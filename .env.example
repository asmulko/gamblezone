# GambleZone environment variables (MVP has no secrets required).
# Copy to .env.local and adjust as needed.

# Public site URL, used for canonical/sitemap/OpenGraph.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare Turnstile bot protection.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Contact form SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CONTACT_EMAIL=info@gamblezone.vip

# Newsletter contacts.
RESEND_API_KEY=
